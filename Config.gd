# ============================================================================
# 可调数值参数（debug 调参的单一来源）
# 返回一份全新的字典，便于运行时被调试面板修改而不污染常量
# ============================================================================
static func default_tune() -> Dictionary:
	return {
		# —— 惯性（越大越灵敏，越小越笨重） ——
		"player_accel": 0.22,
		"security_accel": 0.03,
		"security_accel_elite": 0.085,
		"fb_accel": 0.10,
		# —— 镜头 ——
		"camera_zoom": 0.95,        # 相机缩放：值越大画面越大（越近）；0.72 偏远，1.0 为 1:1
		# —— 速度 ——
		"player_base_speed": 2.6,
		"sprint_mult": 1.8,
		"sec_ratio": 0.80,          # 保安速度 = 主角基础速度 × 此比例（已调快）
		"sec_ratio_elite": 0.98,    # 精英几乎与主角同速
		"star_speed": 2.5,
		"common_speed": 1.9,
		# —— 体力 ——
		"star_stamina": 170.0,
		"common_stamina": 55.0,
		# —— 保安 ——
		"base_security": 5,         # 初始保安数量
		"max_security": 42,         # 场上保安数量上限
		"sec_separation_radius": 50.0,  # 保安互斥半径（避免重叠走同一条路）
		"sec_separation_force": 0.9,    # 互斥强度
		# —— 翻滚 ——
		"roll_cost": 10.0,          # 翻滚体力消耗（之前 5，翻倍）
		"roll_speed": 7.5,          # 翻滚速度（缩短距离）
		"roll_duration": 12.0,      # 翻滚持续帧（缩短距离）
	}
