# ============================================================================
# 可调数值参数（debug 调参的单一来源）
# 返回一份全新的字典，便于运行时被调试面板修改而不污染常量
# ============================================================================
static func default_tune() -> Dictionary:
	return {
		# ================= 难度速查（想更简单：↓保安、↓保安速度、↓拍照帧数、↓吉祥物速度）=================

		# —— 惯性（越大越灵敏/急停，越小越笨重/滑） ——
		"player_accel": 0.22,           # 主角加速度
		"security_accel": 0.03,         # 普通保安加速度
		"security_accel_elite": 0.085,  # 精英保安加速度
		"fb_accel": 0.10,               # 球员加速度

		# —— 镜头 ——
		"camera_zoom": 1.3,             # 相机缩放：值越大画面越大（越近）；0.72 偏远，1.0 为 1:1

		# —— 速度 ——
		"player_base_speed": 2.7,       # 主角基础移速（↑更好逃）
		"sprint_mult": 1.9,             # 按 Shift 冲刺时的速度倍率
		"sec_ratio": 0.68,              # 普通保安速度 = 主角基础速度 × 此比例（↓更容易甩开）
		"sec_ratio_elite": 0.88,        # 精英保安速度比例
		"star_speed": 2.5,              # 球星(10/7号)逃跑速度
		"common_speed": 1.9,            # 普通球员速度

		# —— 体力 ——
		"star_stamina": 170.0,          # 球星体力（越高越能逃）
		"common_stamina": 55.0,         # 普通球员体力

		# —— 保安数量/刷新（核心难度）——
		"base_security": 4,             # 初始保安数量
		"max_security": 42,             # 场上保安数量上限（↓最直接的降难度手段）
		"sec_spawn_interval_mult": 3,   # 保安生成间隔倍率（越大刷得越慢）
		"sec_grow_time": 18.0,          # 每存活 N 帧目标保安 +1（越大刷得越慢）
		"sec_grow_score": 1500.0,       # 每得 N 分目标保安 +1
		"sec_grow_photo": 8.0,          # 每合影 N 人目标保安 +1
		"sec_separation_radius": 70.0,  # 保安互斥半径（避免重叠走同一条路）
		"sec_separation_force": 0.9,    # 互斥强度

		# —— 翻滚（空格，带无敌帧）——
		"roll_cost": 10.0,              # 翻滚体力消耗
		"roll_speed": 7.5,              # 翻滚速度
		"roll_duration": 12.0,          # 翻滚持续帧

		# —— 吉祥物 mini-boss ——
		# 每只各自的速度倍率/休息见 Game.gd 的 MASCOT_DEFS；下面是叠加其上的全局倍率
		"mascot_speed_mult": 0.7,       # 全局倍率（1.0 = 用各自 5/6/7 倍；↓更容易躲）

		# —— 拍照（合影）——
		"photo_frames": 50.0,           # 合影成功需要的累计帧数（↓拍得更快，更好通关）
		"photo_base_range": 50.0,       # 合影判定基础半径（再乘升级 photo_radius）

		# —— 计分 ——
		"survive_score_per_sec": 10,    # 每存活 1 秒加的分
		"photo_score": 150,             # 普通球员合影得分
		"star_score": 400,              # 球星合影得分（被贴脸追拍再 ×2）

		# —— 狂热值 / 暴动 ——
		"riot_regen_per_sec": 5.0,      # 狂热值每秒被动回涨
		"riot_photo_gain": 18.0,        # 合影普通球员加的狂热
		"riot_star_gain": 35.0,         # 合影球星加的狂热
		"riot_duration": 480.0,         # 一次暴动持续帧（约 8 秒）
		"riot_distract_count": 5,       # 暴动时被引开的最近保安数量
		"goal_riot_gain": 10.0,         # 足球进门加的狂热

		# —— 险险闪避（MISS）——
		"dodge_score": 20,              # 闪避一次加的分
		"dodge_riot": 10.0,             # 闪避一次加的狂热

		# —— 足球 ——
		"ball_base_radius": 11.0,       # 足球基础半径（再乘升级 ball_size）
		"ball_kick_speed": 11.0,        # 触球踢出的初速（再乘升级 ball_size）
		"ball_friction": 0.975,         # 每帧滚动摩擦（越小停得越快）

		# —— 跌倒 / 苏醒 ——
		"fall_duration": 300.0,         # 被球撞翻后躺地的帧数（约 5 秒）
		"wake_duration": 180.0,         # 苏醒后减速恢复时长（约 3 秒）
		"wake_min": 0.15,               # 刚苏醒瞬间的速度系数

		# —— 升级 ——
		"upgrade_picks": 2,             # 每次升级可选几个技能
		"gold_card_chance": 0.05,       # 升级时刷出「金牌·全场狂热」的概率
	}
